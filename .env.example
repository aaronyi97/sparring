# 对练场 v1 需要的 8 路凭证（按下方变量名填入你自己的端点与 key 即可）
# 全部走 OpenAI 兼容口径；base_url 缺失 = fail-closed 直接报错，不会静默回退官方端点

# 贡献者A + 门卫/分歧分析（gpt-5.4，OpenAI 兼容中转）
OPENAI_BASE_URL=https://your-openai-proxy/v1
OPENAI_GPT52_API_KEY=sk-xxx
OPENAI_GPT53_CODEX_API_KEY=sk-xxx

# 贡献者B + 综合（gemini-3.1-pro，中转）
GEMINI_PRO_BASE_URL=https://your-gemini-pro-proxy/v1
GEMINI_PRO_API_KEY=ak-xxx

# 收口判定器（gemini-3.1-flash-lite，中转）
GEMINI_FLASH_BASE_URL=https://your-gemini-flash-proxy/v1
GEMINI_FLASH_API_KEY=sk-xxx

# 教练 + 观察（claude-sonnet-4-6，中转）
CLAUDE_BASE_URL=https://your-claude-proxy/v1
CLAUDE_SONNET_KEY=sk-xxx

# 贡献者C（kimi-k2.5，Moonshot 官方；海外 IP 需设 CHINA_PROXY，国内不设即直连）
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_OFFICIAL_API_KEY_1=sk-xxx
# CHINA_PROXY=http://...

# 贡献者替补（deepseek，官方）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-xxx
